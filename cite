#!/usr/bin/env bash
# cite , find the source behind a post's claims and emit VERIFIED citation links.
#
# the agent does the judgment (which claims warrant a cite, which source backs each, which lines);
# this script does the error-prone mechanics:
#   - build a SHA-pinned github permalink, VALIDATED against the local repo at that sha, and refusing
#     to pin to an UNPUSHED sha (which would 404). a wrong/dead code cite can't reach the diff.
#   - verify a url resolves (HTTP 200).
#   - preflight a repo (slug, HEAD, pushed?, dirty?) so the agent knows the state before it cites.
# the agent decides WHAT to cite (judgment); the helper does the mechanics, incl. a SAFE insert
# (verify + exactly-one literal match + wrap) so a missed/ambiguous add can't pass silently. See SKILL.md.
# mirrors hush's shape: a contract + one focused script.

set +x 2>/dev/null || true
unset BASH_XTRACEFD 2>/dev/null || true
set -uo pipefail

VERSION=3.20.3

die() {
  [ "${CITE_JSON:-0}" = 1 ] && printf '{"error":"%s","ok":false}\n' "$(_jesc "$1")"
  printf 'cite: %s\n' "$1" >&2; exit 1
}

usage() {
  cat >&2 <<'EOF'
cite , verified citation links for an agent. The agent decides WHAT to cite; this builds + checks. Full doctrine: SKILL.md.

  cite verify <url> | cite verify -   resolves? HTTP code + dead-vs-gated hint + redirect (batch: parallel, JSONL)
  cite links <file>                   every link url (md / html href / refs / autolinks / bare), images excluded
  cite insert <file> <phrase> <url>   verify <url> + wrap the FIRST citable match (skips code + existing links)
  cite prove <file> [ref]             assert ONLY link markup changed vs ref (default HEAD); fails on any prose edit
  cite lint <file>                    catch the url-as-text half-fix (--fix syncs it)
  cite flag <post> <reason...>        record a dead link / dubious claim (with its url) to .cite-flags.md
  cite check <post> [base]            optional audit: verify all links + prove + lint -> PASS/ISSUES
  cite sweep <repo-dir> <base>        prove + lint over every changed .md (batch backstop)
  cite preflight <repo-dir>           (code mode) slug / HEAD / pushed / visibility
  cite permalink <repo-dir> <path> <start> [end] [--ref <ref>]   (code mode) sha-pinned, range-validated
  cite version

Flags: --json (links/verify/lint/check) , --crosscheck (verify) , --relative (links) , --fix (lint).
Use -- to end flags when a phrase/reason IS a flag token: cite insert post.md -- --fix <url>.
Note: prove/flag/check/sweep need the file in a git repo; links/verify/lint do not.
EOF
  exit "${1:-2}"
}

# parse owner/repo from a github remote url (git@github.com:o/r.git or https://github.com/o/r(.git))
gh_slug() {
  local url="$1"; url="${url%.git}"
  case "$url" in
    git@github.com:*)     printf '%s' "${url#git@github.com:}" ;;
    https://github.com/*) printf '%s' "${url#https://github.com/}" ;;
    *) return 1 ;;
  esac
}

# is <sha> reachable from any remote-tracking branch (i.e. pushed)?
sha_is_pushed() { [ -n "$(git -C "$1" branch -r --contains "$2" 2>/dev/null)" ]; }

cmd_permalink() {
  local ref="" dir="" path="" start="" end="" pos=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --ref)   ref="${2:-}"; [ -n "$ref" ] || die "permalink: --ref needs a value"; shift 2 ;;
      --ref=*) ref="${1#--ref=}"; shift ;;
      *) case "$pos" in
           0) dir="$1" ;; 1) path="$1" ;; 2) start="$1" ;; 3) end="$1" ;;
           *) die "permalink: too many arguments" ;;
         esac; pos=$((pos + 1)); shift ;;
    esac
  done
  { [ -n "$dir" ] && [ -n "$path" ] && [ -n "$start" ]; } || usage
  case "$start" in ''|*[!0-9]*) die "permalink: start line must be a number";; esac
  [ -n "$end" ] && case "$end" in ''|*[!0-9]*) die "permalink: end line must be a number";; esac
  [ "$start" -ge 1 ] 2>/dev/null || die "permalink: start line must be >= 1 (got $start)"
  [ -n "$end" ] && { [ "$end" -ge "$start" ] 2>/dev/null || die "permalink: end ($end) is before start ($start)"; }
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not a git repo: $dir"
  local remote slug sha
  remote="$(git -C "$dir" remote get-url origin 2>/dev/null)" || die "no 'origin' remote in $dir"
  slug="$(gh_slug "$remote")" || die "origin is not a github remote: $remote"
  if [ -n "$ref" ]; then
    sha="$(git -C "$dir" rev-parse --verify "$ref^{commit}" 2>/dev/null)" || die "cannot resolve ref '$ref' in $dir"
  else
    sha="$(git -C "$dir" rev-parse HEAD 2>/dev/null)" || die "cannot resolve HEAD in $dir"
    sha_is_pushed "$dir" "$sha" || die "HEAD ($sha) isn't pushed to any remote , the permalink would 404. push it, or pass --ref origin/<branch> to pin to a public commit."
  fi
  git -C "$dir" cat-file -e "$sha:$path" 2>/dev/null || die "no '$path' at $sha"
  local n last; n="$(git -C "$dir" show "$sha:$path" | awk 'END{print NR}')"; last="${end:-$start}"
  [ "$last" -le "$n" ] 2>/dev/null || die "line $last out of range ($path has $n lines at $sha)"
  if [ -n "$end" ] && [ "$end" != "$start" ]; then
    printf 'https://github.com/%s/blob/%s/%s#L%s-L%s\n' "$slug" "$sha" "$path" "$start" "$end"
  else
    printf 'https://github.com/%s/blob/%s/%s#L%s\n' "$slug" "$sha" "$path" "$start"
  fi
}

_probe() { command -v curl >/dev/null 2>&1 || die "cite needs curl to check links (deps: bash, git, curl, perl)"; curl -s -o /dev/null -w '%{http_code}|%{url_effective}' -L --max-time 20 "$1" 2>/dev/null; }
# compare urls ignoring only scheme + trailing slash, so http->https / trailing-slash redirects are
# not flagged but a real path/host move (the macvlan docs.docker.com/network->engine case) is.
_norm() { printf '%s' "$1" | sed -e 's#^https\{0,1\}://##' -e 's#/$##'; }
# scheme://host/ of a url , for the --crosscheck root probe.
_host_root() { printf '%s' "$1" | sed -E 's#^(https?://[^/]+).*#\1/#'; }
# escape a string for embedding in a JSON double-quoted value.
_jesc() { printf '%s' "${1:-}" | perl -pe 's/([\\"])/\\$1/g; s/\n/\\n/g; s/\r/\\r/g; s/\t/\\t/g; s/([\x00-\x1f])/sprintf("\\u%04x",ord($1))/ge' 2>/dev/null; }
# build a JSON array from stdin in ONE perl pass (not one _jesc spawn per item , the 200x bottleneck).
# NOTE: escape order mirrors _jesc EXACTLY (\r,\t short-forms before the generic \u rule) so single-pass
# output is byte-identical to the old per-item _jesc, not just decode-equal. (\n can't survive split /\n/.)
_json_arr()  { perl -0777 -ne 'my @x; for my $v (split /\n/,$_){ next if $v=~/^\s*$/; $v=~s/([\\"])/\\$1/g; $v=~s/\r/\\r/g; $v=~s/\t/\\t/g; $v=~s/([\x00-\x1f])/sprintf("\\u%04x",ord($1))/ge; push @x,"\"$v\"" } print "[".join(",",@x)."]"' 2>/dev/null; }
_json_objs() { perl -0777 -ne 'my @x; for my $l (split /\n/,$_){ next unless $l=~/\t/; my($t,$h)=split /\t/,$l,2; for my $v ($t,$h){ $v=~s/([\\"])/\\$1/g; $v=~s/\r/\\r/g; $v=~s/([\x00-\x1f])/sprintf("\\u%04x",ord($1))/ge } push @x,"{\"text\":\"$t\",\"href\":\"$h\"}" } print "[".join(",",@x)."]"' 2>/dev/null; }
# turn a non-200 code into a dead-vs-gated hint, so the agent doesn't have to hand-roll the diagnosis.
_codehint() {
  case "$1" in
    403|429|503) printf 'often bot/JS-gated , cross-check a non-gated source (registry index/api) before calling it dead' ;;
    404|410)     printf 'likely dead' ;;
    000)         printf 'no response / timeout' ;;
    3*)          printf 'redirect , prefer the final url' ;;
    *)           printf 'not 200' ;;
  esac
}

# emit one verify result for <url> (text or JSON per CITE_JSON), optionally crosschecking dead-vs-gated
# via a host-root probe (CITE_XCHECK). returns 0 iff the url resolves (HTTP 200).
_verify_emit() {
  local url="${1:-}" res code final redir hint root rcode
  [ -n "$url" ] || return 0
  res="$(_probe "$url")"; code="${res%%|*}"; final="${res#*|}"
  if [ "$code" = "200" ]; then
    redir=""; { [ -n "$final" ] && [ "$(_norm "$final")" != "$(_norm "$url")" ]; } && redir="$final"
    if [ "${CITE_JSON:-0}" = 1 ]; then
      if [ -n "$redir" ]; then printf '{"url":"%s","ok":true,"code":"200","final":"%s"}\n' "$(_jesc "$url")" "$(_jesc "$redir")"
      else printf '{"url":"%s","ok":true,"code":"200"}\n' "$(_jesc "$url")"; fi
    elif [ -n "$redir" ]; then printf 'ok    %s  -> %s  (redirected , open the final page and confirm it still means the term before linking it)\n' "$url" "$redir"
    else printf 'ok    %s\n' "$url"; fi
    return 0
  fi
  hint="$(_codehint "${code:-000}")"
  if [ "${CITE_XCHECK:-0}" = 1 ]; then
    root="$(_host_root "$url")"; rcode="$(_probe "$root")"; rcode="${rcode%%|*}"
    if [ "$rcode" = "200" ]; then hint="host root is 200 but this path is ${code:-000} , likely DEAD (page gone)"
    else hint="host root is also ${rcode:-000} , likely a host-wide GATE not a dead page (confirm via a non-gated index)"; fi
  fi
  if [ "${CITE_JSON:-0}" = 1 ]; then printf '{"url":"%s","ok":false,"code":"%s","hint":"%s"}\n' "$(_jesc "$url")" "${code:-000}" "$(_jesc "$hint")"
  else printf 'FAIL  %s  (HTTP %s , %s)\n' "$url" "${code:-000}" "$hint"; fi
  return 1
}

cmd_verify() {
  local url="${1:-}"; [ -n "$url" ] || usage
  if [ "$url" = "-" ]; then
    # batch: read urls on stdin, verify in PARALLEL (output unordered, each line complete), nonzero if any fail.
    export CITE_JSON CITE_XCHECK
    local results pflag jobs="${CITE_JOBS:-16}" items nin
    # -n1 (not -I{}): -I has a 255-byte replstr limit that silently DROPS long urls; -n1 appends the url
    # as a positional arg with no cap. -P jobs (default 16, tunable via CITE_JOBS, validated at dispatch) ,
    # verify is pure network wait, so width is the only lever and 16 ~halves wall time vs 8. busybox xargs
    # has no -P; probe with the REAL jobs value (not a hardcoded 2) and fall back to sequential if -P is
    # unsupported, so batch still WORKS (just slower) instead of erroring.
    items="$(sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' | grep -v '^[[:space:]]*$' | awk '!seen[$0]++')"
    nin="$(printf '%s' "$items" | grep -c .)"
    [ "$nin" -eq 0 ] && return 0
    if printf '' | xargs -P "$jobs" true >/dev/null 2>&1; then pflag="-P $jobs"; else pflag=""; fi
    results="$(printf '%s\n' "$items" | xargs $pflag -n1 "$0" __vone 2>/dev/null)"
    # a non-empty input that produced NO output means the fan-out itself broke (xargs error, etc.) , that
    # must read as failure, never as a silent all-clear (the fail-open the CITE_JOBS bug exposed).
    [ -z "$results" ] && { printf 'cite: verify produced no output for %s url(s) , the parallel fan-out failed (check CITE_JOBS / xargs)\n' "$nin" >&2; return 1; }
    printf '%s\n' "$results"
    if [ "${CITE_JSON:-0}" = 1 ]; then printf '%s' "$results" | grep -q '"ok":false' && return 1 || return 0
    else printf '%s' "$results" | grep -q '^FAIL' && return 1 || return 0; fi
  fi
  _verify_emit "$url"
}

# extract every link url from a file, one per line, deduped (order kept). covers BOTH markdown links
# [text](url) , tolerant of one level of nested parens like wikipedia ..._(computing) , AND html
# <a href="url"> anchors/badges (a README's top badges are html, not markdown , don't miss them).
# mask out fenced (``` / ~~~) code blocks and inline `code` spans so example links inside them are not
# treated as real links (a doc that documents a dead example url must not fail the gate, and lint --fix
# must never rewrite content inside code).
# THE single definition of a "code region": html comment, fenced (``` or ~~~) block, double/single inline
# code. everything that must skip code , _mask_code, _strip (prove), cmd_insert, lint --fix , consumes
# this one pattern via $ENV{CITE_CR}, so they can never diverge (the class behind the tilde + insert bugs).
export CITE_CR='<!--.*?-->|(?:`{3,}|~{3,})[^\n]*\n.*?\n[ \t]*(?:`{3,}|~{3,})[^\n]*|``.*?``|`[^`\n]+`'
_mask_code() { perl -0777 -pe 'my $cr=$ENV{CITE_CR}; s/$cr//gs' 2>/dev/null; }
cmd_links() {
  local f="${1:-}"; [ -n "$f" ] || usage
  [ -f "$f" ] || die "links: no file '$f'"
  local urls rel masked
  masked="$(_mask_code < "$f")"
  # collapse images ![alt](src) to their alt text BEFORE link extraction: drops standalone badge srcs
  # (images aren't citations) AND exposes the OUTER target of a linked badge [![alt](src)](target).
  masked="$(printf '%s' "$masked" | perl -0777 -pe 's/!\[([^\]]*)\]\((?:[^()\s]|\([^()\s]*\))*\)/$1/g' 2>/dev/null)"
  # every link FORM that renders clickable: inline [t](url), html href, reference defs [label]: url,
  # angle-bracket autolinks <url>, bare urls. SLURP (-0777) like _strip/_lint_scan so a link whose
  # visible text spans a soft line break is not silently dropped (the line-mode blind spot).
  urls="$(printf '%s' "$masked" | perl -0777 -ne '
    while(/\[[^\]]*\]\((https?:\/\/(?:[^()\s]|\([^()\s]*\))+)\)/g){print "$1\n"}
    while(/href\s*=\s*(["\x27]?)(https?:\/\/[^"\x27\s>]+)\1/gi){print "$2\n"}
    while(/^[ ]{0,3}\[[^\]]+\]:\s+(\S+)/mg){ my $u=$1; $u=~s/^<//; $u=~s/>$//; print "$u\n" if $u=~m{^https?://} }
    while(/<(https?:\/\/[^>\s]+)>/g){print "$1\n"}
    while(/(?:^|\s)(https?:\/\/[^\s<>()\[\]"\x27]+)/mg){ my $u=$1; $u=~s/[.,;:!?]+$//; print "$u\n" }
  ' | awk '!seen[$0]++')"
  # relative targets (not http) , inline + reference-definition. break outside the repo; absolutize the
  # load-bearing ones. surfaced on --relative or --json.
  rel="$(printf '%s' "$masked" | perl -0777 -ne '
    while(/\[[^\]]*\]\(([^()\s][^()]*)\)/g){ my $u=$1; next if $u=~m{^https?://}; print "$u\n" }
    while(/^[ ]{0,3}\[[^\]]+\]:\s+(\S+)/mg){ my $u=$1; $u=~s/^<//; $u=~s/>$//; next if $u=~m{^https?://}; print "$u\n" }
  ' | awk '!seen[$0]++')"
  if [ "${CITE_JSON:-0}" = 1 ]; then
    printf '{"urls":%s,"relative":%s}\n' "$(printf '%s' "$urls" | _json_arr)" "$(printf '%s' "$rel" | _json_arr)"
    return 0
  fi
  [ -n "$urls" ] && printf '%s\n' "$urls"
  if [ "${CITE_REL:-0}" = 1 ] && [ -n "$rel" ]; then
    printf 'relative links (not http , verify by hand; absolutize the load-bearing ones for portability):\n' >&2
    printf '%s\n' "$rel" | sed 's/^/  /' >&2
  fi
  return 0
}

# reduce a doc to its PROSE for comparison: strip markdown links/images and html anchors to their
# visible text, then tokenize any remaining url to <URL>. so fixing a dead link , including one whose
# visible text is itself a url (the heroku half-fix) , reads as a no-op, while a real prose word change
# (dumb->super-simple), a link-TEXT edit (mat->rug), or line-ending churn still shows up.
_strip() {
  perl -0777 -pe '
    my $cr=$ENV{CITE_CR};
    my @p = split /($cr)/s, $_;            # odd indices = code regions, left VERBATIM
    for my $i (0..$#p) {
      next if $i % 2;                       # so a link injected INTO code shows as a diff (prove fails),
      $p[$i] =~ s/!?\[([^\]]*)\]\((?:[^()\s]|\([^()\s]*\))*\)/$1/g;   # not a markup-only no-op.
      $p[$i] =~ s/<a\b[^>]*?>(.*?)<\/a>/$1/gis;
      $p[$i] =~ s/https?:\/\/[^\s<>"]+/<URL>/g;
    }
    $_ = join "", @p;
  ' 2>/dev/null
}

# prove cite changed ONLY link markup in <file> vs <ref> (default HEAD): strip both versions to their
# visible text and assert equality. catches prose rewrites, link-TEXT edits, and line-ending/whitespace
# churn , the mechanical form of "the diff shows only link markup changed" (step 7), which a human or
# agent can otherwise falsely self-certify (the corpus run's one blocking failure: dumb->super-simple).
cmd_prove() {
  local f="${1:-}" ref="${2:-HEAD}"; [ -n "$f" ] || usage
  [ -f "$f" ] || die "prove: no file '$f'"
  local dir base root rel old olds news
  dir="$(cd "$(dirname "$f")" && pwd -P)" || die "prove: cannot resolve '$f'"
  base="$(basename "$f")"
  root="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)" || die "prove: not in a git repo: $f"
  if [ "$dir" = "$root" ]; then rel="$base"; else rel="${dir#"$root"/}/$base"; fi
  old="$(git -C "$root" show "$ref:$rel" 2>/dev/null)" || die "prove: '$rel' not found at $ref (new file? nothing to prove against)"
  olds="$(printf '%s' "$old" | _strip)"
  news="$(_strip < "$f")"
  if [ "$olds" = "$news" ]; then
    printf 'prove: %s , only link markup changed; prose intact.\n' "$rel"
    # footgun guard: a bare prove (default HEAD) after committing compares the file to its own commit and
    # passes trivially. if there's no diff at all vs HEAD, nudge to pass the base ref.
    [ -z "${2:-}" ] && git -C "$root" diff --quiet HEAD -- "$rel" 2>/dev/null && \
      printf 'prove: note , %s is identical to HEAD (nothing to prove). if you already committed the cites, pass the base ref: cite prove %s <base>.\n' "$rel" "$base" >&2
  else
    printf 'prove: PROSE CHANGED in %s , cite must not rewrite prose. visible-text diff (- was, + now):\n' "$rel" >&2
    local _o _n; _o="$(mktemp)"; _n="$(mktemp)"; printf '%s\n' "$olds" > "$_o"; printf '%s\n' "$news" > "$_n"
    diff "$_o" "$_n" >&2; rm -f "$_o" "$_n"
    exit 1
  fi
  return 0
}

# lint for the "half-fix": a link whose VISIBLE TEXT is itself a url but differs from the href (href
# repointed to a live canonical, stale/dead url left as the displayed text , the heroku pattern). cite
# prove cannot catch this (a url->url text change is a no-op to it), so this is the mechanical backstop
# the recurring failure needs. run it after editing; sync the visible text to the href, or use
# descriptive text instead of a raw url.
# scan for half-fixes; print one "text<TAB>href" line per offender (no decoration). code-masked so a
# url-as-text link that is a teaching example inside ``` or `code` is not flagged (and never auto-fixed).
_lint_scan() {
  _mask_code < "$1" | perl -0777 -ne '
    while(/(?<!\!)\[([^\]]*)\]\(((?:[^()\s]|\([^()\s]*\))+)\)/g){ my($t,$h)=($1,$2); print "$t\t$h\n" if $t=~m{^https?://} && $t ne $h }
    while(/<a\b[^>]*?href\s*=\s*(["\x27]?)([^"\x27\s>]+)\1[^>]*>(.*?)<\/a>/gis){ my($h,$t)=($2,$3); $t=~s/<[^>]*>//gs; print "$t\t$h\n" if $t=~m{^https?://} && $t ne $h }
  ' 2>/dev/null
}
cmd_lint() {
  local f="${1:-}"; [ -n "$f" ] || usage
  [ -f "$f" ] || die "lint: no file '$f'"
  local fixed=0
  if [ "${CITE_FIX:-0}" = 1 ]; then
    local before; before="$(_lint_scan "$f")"
    # the leading code-span alternative is kept verbatim ($c), so links inside ``` / `code` are never rewritten.
    perl -0777 -i -pe 's{($ENV{CITE_CR})|(?<!\!)\[([^\]]*)\]\(((?:[^()\s]|\([^()\s]*\))+)\)}{ my($c,$t,$h)=($1,$2,$3); defined($c)?$c:(($t=~m{^https?://}&&$t ne $h)?"[$h]($h)":"[$t]($h)") }ges' "$f" 2>/dev/null
    perl -0777 -i -pe 's{($ENV{CITE_CR})|(<a\b[^>]*?href\s*=\s*["\x27]?)([^"\x27\s>]+)(["\x27]?[^>]*>)(.*?)(</a>)}{ my($c,$p,$h,$m,$t,$q)=($1,$2,$3,$4,$5,$6); if(defined($c)){$c}else{ my $tt=$t; $tt=~s/<[^>]*>//gs; ($tt=~m{^https?://}&&$tt ne $h)?"$p$h$m$h$q":"$p$h$m$t$q" } }gise' "$f" 2>/dev/null
    local b a; b="$(printf '%s' "$before" | grep -c .)"; a="$(_lint_scan "$f" | grep -c .)"
    fixed=$(( b - a ))
  fi
  local out; out="$(_lint_scan "$f")"
  if [ "${CITE_JSON:-0}" = 1 ]; then
    if [ -z "$out" ]; then printf '{"clean":true,"fixed":%s,"offenders":[]}\n' "$fixed"; return 0
    else printf '{"clean":false,"fixed":%s,"offenders":%s}\n' "$fixed" "$(printf '%s' "$out" | _json_objs)"; return 1; fi
  fi
  [ "${CITE_FIX:-0}" = 1 ] && printf 'lint --fix: %s , synced %s url-as-text half-fix(es) to their href.\n' "$f" "$fixed"
  if [ -z "$out" ]; then [ "${CITE_FIX:-0}" = 1 ] || printf 'lint: %s , clean (no url-as-visible-text half-fixes).\n' "$f"; return 0; fi
  printf 'lint: %s , a link shows a url as its visible text that differs from its href (run --fix, or sync manually):\n' "$f" >&2
  printf '%s\n' "$out" | sed 's/	/  ->  /; s/^/  half-fix: /' >&2
  return 1
}

# record a durable flag (dead pre-existing link, dubious/unsourced claim, misattribution) to
# .cite-flags.md at the repo root, so 'flag, don't fabricate' findings survive as an inventory instead
# of evaporating into a chat reply.
# safely ADD one citation: verify the url, then wrap the FIRST occurrence of the phrase that is NOT inside
# a code region OR an already-existing link , so a teaching example in code is never corrupted (B's bug)
# and a re-run can't nest [[x](u)](u) (the double-insert bug). errors on 0 citable occurrences (missed add);
# links a term once on purpose (no every-occurrence mode).
cmd_insert() {
  local f="${1:-}" phrase="${2:-}" url="${3:-}"
  { [ -n "$f" ] && [ -n "$phrase" ] && [ -n "$url" ]; } || die "insert: usage , cite insert <file> <phrase> <url>"
  [ -f "$f" ] || die "insert: no file '$f'"
  # the "protected" regions insert must skip: code (shared CITE_CR) + existing md/html links.
  local n; n="$(CITE_PHRASE="$phrase" perl -0777 -ne '
    my $prot = qr/$ENV{CITE_CR}|(?<!\!)\[[^\]]*\]\((?:[^()\s]|\([^()\s]*\))*\)|<a\b[^>]*?>.*?<\/a>/s;
    my @p = split /($prot)/, $_; my $q=quotemeta($ENV{CITE_PHRASE}); my $c=0;
    for my $i (0..$#p){ next if $i%2; $c += (() = $p[$i] =~ /$q/g) }
    print $c+0' "$f" 2>/dev/null)"
  [ "${n:-0}" -ge 1 ] 2>/dev/null || die "insert: '$phrase' not found in citable prose in $f (it may appear only inside code or an existing link, which cite won't touch)"
  local code; code="$(_probe "$url")"; code="${code%%|*}"
  [ "$code" = "200" ] || die "insert: $url -> HTTP ${code:-000} ($(_codehint "${code:-000}")) , not inserting an unverified link"
  local fmt=md; case "$f" in *.html|*.htm) fmt=html;; esac
  CITE_PHRASE="$phrase" CITE_URL="$url" CITE_FMT="$fmt" perl -0777 -i -pe '
    my $prot = qr/$ENV{CITE_CR}|(?<!\!)\[[^\]]*\]\((?:[^()\s]|\([^()\s]*\))*\)|<a\b[^>]*?>.*?<\/a>/s;
    my @p = split /($prot)/, $_; my $q=quotemeta($ENV{CITE_PHRASE}); my $done=0; my $html=($ENV{CITE_FMT} eq "html");
    for my $i (0..$#p){ next if $i%2 || $done;
      if($html){ $done=1 if $p[$i] =~ s/$q/"<a href=\"".$ENV{CITE_URL}."\">".$ENV{CITE_PHRASE}."<\/a>"/e }
      else     { $done=1 if $p[$i] =~ s/$q/"[".$ENV{CITE_PHRASE}."](".$ENV{CITE_URL}.")"/e } }
    $_ = join "", @p' "$f" 2>/dev/null
  printf 'insert: wrapped "%s" -> %s in %s\n' "$phrase" "$url" "$f"
  [ "$n" -gt 1 ] 2>/dev/null && printf 'insert: note , "%s" has %s citable occurrences; linked the FIRST. pass a longer unique phrase to target another.\n' "$phrase" "$n" >&2
  return 0
}

cmd_flag() {
  local f="${1:-}"; shift 2>/dev/null || true; local reason="$*"
  { [ -n "$f" ] && [ -n "$reason" ]; } || die "flag: usage , cite flag <post> <reason...>"
  [ -f "$f" ] || die "flag: no file '$f'"
  local dir root rel ts
  dir="$(cd "$(dirname "$f")" && pwd -P)" || die "flag: cannot resolve '$f'"
  root="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)" || die "flag: not in a git repo: $f"
  if [ "$dir" = "$root" ]; then rel="$(basename "$f")"; else rel="${dir#"$root"/}/$(basename "$f")"; fi
  ts="$(date +%Y-%m-%d 2>/dev/null)"
  printf -- '- [%s] %s , %s\n' "$ts" "$rel" "$reason" >> "$root/.cite-flags.md"
  printf 'flag: recorded to %s/.cite-flags.md\n' "$root"
}

# is <url> recorded in <flags-file>? matches the url as a WHOLE token (extract urls + exact-compare),
# NOT a raw substring , so flagging a longer url can't silently vouch a shorter dead url that is its prefix.
_flagged() {
  grep -oE 'https?://[^[:space:]]+' "$1" 2>/dev/null | sed 's/[.,;:!?]*$//' | grep -qxF "$2"
}

# sweep an entire batch/corpus run: for every .md changed vs <base>, run the two mechanical gates
# (prove + lint) and report offenders. this is the harness-enforced backstop , a corpus run's per-post
# agent diligence is uneven, so don't trust self-reports; sweep the whole diff at the end.
cmd_sweep() {
  local dir="${1:-}" base="${2:-}"
  { [ -n "$dir" ] && [ -n "$base" ]; } || die "sweep: usage , cite sweep <repo-dir> <base-ref>"
  [ -d "$dir" ] || die "sweep: no dir '$dir'"
  local root; root="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)" || die "sweep: not a git repo: $dir"
  git -C "$root" rev-parse --verify "$base^{commit}" >/dev/null 2>&1 || die "sweep: cannot resolve base ref '$base'"
  local files n=0 pf=0 lf=0 rel
  files="$(git -C "$root" diff --name-only "$base" -- '*.md' 2>/dev/null)"
  [ -n "$files" ] || { printf 'sweep: no changed .md files vs %s.\n' "$base"; return 0; }
  while IFS= read -r rel; do
    [ -n "$rel" ] || continue
    n=$((n + 1))
    if git -C "$root" cat-file -e "$base:$rel" 2>/dev/null; then
      ( cmd_prove "$root/$rel" "$base" ) >/dev/null 2>&1 || { printf 'PROSE-CHANGED  %s\n' "$rel"; pf=$((pf + 1)); }
    fi
    ( cmd_lint "$root/$rel" ) >/dev/null 2>&1 || { printf 'HALF-FIX       %s\n' "$rel"; lf=$((lf + 1)); }
  done <<EOF
$files
EOF
  printf 'sweep: %s changed .md vs %s , %s prose-changed, %s half-fix.\n' "$n" "$base" "$pf" "$lf"
  { [ "$pf" -eq 0 ] && [ "$lf" -eq 0 ]; }
}

# one-shot: run all the gates on a single post , verify every link, prove vs base, lint , and report a
# consolidated PASS/ISSUES. lowers the per-post ceremony (four commands -> one) so agents skip fewer gates.
cmd_check() {
  local f="${1:-}" base="${2:-HEAD}"; [ -n "$f" ] || usage
  [ -f "$f" ] || die "check: no file '$f'"
  local dir root rel
  dir="$(cd "$(dirname "$f")" && pwd -P 2>/dev/null)"
  root="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)" || root=""
  # verify all links; a failure whose url is recorded in .cite-flags.md is a KNOWN flagged link (the
  # flag-don't-remove contract), so it counts as 'flagged, known', not a gate failure.
  local links nlink vout u nfail=0 flagged=0 ffail=""
  links="$(CITE_JSON=0 CITE_REL=0 cmd_links "$f" 2>/dev/null)"
  nlink="$(printf '%s' "$links" | grep -c .)"
  [ -n "$links" ] && vout="$(printf '%s\n' "$links" | CITE_JSON=0 cmd_verify - 2>/dev/null)"
  # if there were links but verify emitted nothing, the fan-out broke (cmd_verify swallows stderr here) ,
  # count every link as a failure rather than let an empty result read as all-clear (a check fail-open).
  if [ "${nlink:-0}" -gt 0 ] && [ -z "${vout:-}" ]; then nfail="$nlink"; ffail="(verify produced no output , parallel fan-out failed; check CITE_JOBS/xargs)"; fi
  while IFS= read -r u; do
    [ -n "$u" ] || continue
    if [ -n "$root" ] && [ -f "$root/.cite-flags.md" ] && _flagged "$root/.cite-flags.md" "$u"; then flagged=$((flagged + 1))
    else nfail=$((nfail + 1)); ffail="${ffail}${u}"$'\n'; fi
  done <<EOF
$(printf '%s\n' "${vout:-}" | awk '/^FAIL/{print $2}')
EOF
  # prove WITH a reason , distinguish a real prose change (a failure) from prove being inapplicable
  # (file absent at base / not a git repo), which is NOT a failure of the agent's edits.
  local pstatus="ok" pfail=0
  if [ -z "$root" ]; then pstatus="skipped (not a git repo)"
  else
    if [ "$dir" = "$root" ]; then rel="$(basename "$f")"; else rel="${dir#"$root"/}/$(basename "$f")"; fi
    if ! git -C "$root" cat-file -e "$base:$rel" 2>/dev/null; then pstatus="skipped (file absent at $base)"
    elif ( cmd_prove "$f" "$base" ) >/dev/null 2>&1; then pstatus="prose intact"
    else pstatus="PROSE CHANGED vs $base"; pfail=1; fi
  fi
  local nlint flagrec=0 loff; loff="$(_lint_scan "$f")"; nlint="$(printf '%s' "$loff" | grep -c .)"   # one scan, reused
  { [ -n "$root" ] && [ -f "$root/.cite-flags.md" ]; } && flagrec="$(grep -c '^- ' "$root/.cite-flags.md" 2>/dev/null || echo 0)"
  local ok=1; { [ "$nfail" -eq 0 ] && [ "$pfail" -eq 0 ] && [ "${nlint:-0}" -eq 0 ]; } || ok=0
  if [ "${CITE_JSON:-0}" = 1 ]; then
    printf '{"file":"%s","links":%s,"link_failures":%s,"flagged_known":%s,"failed_urls":%s,"prove":"%s","half_fixes":%s,"offenders":%s,"flags_recorded":%s,"ok":%s}\n' \
      "$(_jesc "$f")" "${nlink:-0}" "$nfail" "$flagged" "$(printf '%s' "$ffail" | _json_arr)" "$(_jesc "$pstatus")" "${nlint:-0}" "$(printf '%s' "$loff" | _json_objs)" "${flagrec:-0}" "$([ "$ok" -eq 1 ] && echo true || echo false)"
    [ "$ok" -eq 1 ]; return
  fi
  printf 'check %s (vs %s):\n' "$f" "$base"
  if [ "$flagged" -gt 0 ]; then printf '  links: %s checked, %s failed (%s flagged, known)\n' "${nlink:-0}" "$nfail" "$flagged"
  else printf '  links: %s checked, %s failed\n' "${nlink:-0}" "$nfail"; fi
  if [ "$nfail" -gt 0 ]; then
    printf '%s\n' "${vout:-}" | awk '/^FAIL/{print $2}' | while IFS= read -r u; do
      [ -n "$u" ] || continue
      { [ -n "$root" ] && [ -f "$root/.cite-flags.md" ] && _flagged "$root/.cite-flags.md" "$u"; } || printf '         dead: %s\n' "$u"
    done
  fi
  printf '  prove: %s\n' "$pstatus"
  printf '  lint:  %s\n' "$([ "${nlint:-0}" -eq 0 ] && echo 'clean' || echo "${nlint} half-fix(es) , run cite lint --fix")"
  [ "${flagrec:-0}" -gt 0 ] 2>/dev/null && printf '  flags: %s recorded in .cite-flags.md (read it , url-less claim flags do not show above)\n' "$flagrec"
  [ "$ok" -eq 1 ] && printf '  => PASS\n' || printf '  => ISSUES\n'
  [ "$ok" -eq 1 ]
}

cmd_preflight() {
  local dir="${1:-}"; [ -n "$dir" ] || usage
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not a git repo: $dir"
  local remote slug sha pushed dirty
  local vis
  remote="$(git -C "$dir" remote get-url origin 2>/dev/null)" || remote="(none)"
  slug="$(gh_slug "$remote" 2>/dev/null)" || slug="(not a github remote: $remote)"
  sha="$(git -C "$dir" rev-parse HEAD 2>/dev/null)" || sha="(no HEAD)"
  if sha_is_pushed "$dir" "$sha"; then pushed=yes; else pushed=no; fi
  if [ -n "$(git -C "$dir" status --porcelain 2>/dev/null)" ]; then dirty=yes; else dirty=no; fi
  vis="$(gh repo view "$slug" --json visibility -q '.visibility' 2>/dev/null | tr '[:upper:]' '[:lower:]')"
  [ -n "$vis" ] || vis="unknown"
  printf 'repo:       %s\nslug:       %s\nvisibility: %s\nHEAD:       %s\npushed:     %s\ndirty:      %s\n' \
    "$dir" "$slug" "$vis" "$sha" "$pushed" "$dirty"
  [ "$pushed" = yes ] || printf 'note:       HEAD is not pushed , pin with `cite permalink ... --ref origin/<branch>` (or push first), else the links 404.\n'
  [ "$vis" = private ] && printf 'note:       repo is PRIVATE , do NOT cite it; its links 404 for anyone but you. find a public source or skip the cite.\n'
  return 0
}

# global flags (inherited from env when re-invoked by xargs, else off): --json structured output,
# --crosscheck dead-vs-gated root probe, --fix auto-repair (lint), --relative include relative links.
# the scan is position-independent (so `cite links f --json` works), so a `--` end-of-options escape is
# required: everything after a literal `--` is taken verbatim, so you can cite/flag a phrase that IS a flag
# token (e.g. `cite insert post.md -- --fix <url>`) without it being swallowed or flipping a mode.
CITE_JSON="${CITE_JSON:-0}"; CITE_XCHECK="${CITE_XCHECK:-0}"; CITE_FIX="${CITE_FIX:-0}"; CITE_REL="${CITE_REL:-0}"
_a=(); _endopts=0
for _x in "$@"; do
  if [ "$_endopts" = 1 ]; then _a+=("$_x"); continue; fi
  case "$_x" in
    --)           _endopts=1 ;;
    --json)       CITE_JSON=1 ;;
    --crosscheck) CITE_XCHECK=1 ;;
    --fix)        CITE_FIX=1 ;;
    --relative)   CITE_REL=1 ;;
    *) _a+=("$_x") ;;
  esac
done
set -- ${_a[@]+"${_a[@]}"}

cmd="${1:-}"; shift || true
# preflight: perl is the load-bearing engine (extraction, the prove/lint gates, insert). without it every
# perl call silently no-ops (2>/dev/null), so prove/insert would PASS while doing NOTHING , fail OPEN, the
# dangerous kind. probe perl with the ACTUAL work mode (a -0777 -pe round-trip A->B), not just `perl -e1`:
# a stub / wrong-arch / corrupt perl can satisfy -e1 yet no-op or error on the real slurp+substitute mode,
# which reopens the fail-open. the round-trip dies loud unless perl genuinely transforms input.
# __vone is exempt: it's the internal per-url worker the batch re-invokes via xargs, and the parent's
# dispatch already ran this gate once , re-checking would spawn a perl probe PER url (the per-url-spawn
# anti-pattern v3.19 removed).
case "$cmd" in
  version|--version|-V|""|-h|--help|help|__vone) : ;;
  *) [ "$(printf A | perl -0777 -pe 's/A/B/' 2>/dev/null)" = B ] || die "cite needs a working perl (deps: bash, git, curl, perl). on Windows, run in WSL or git-bash with perl installed; native PowerShell/cmd is unsupported." ;;
esac
# CITE_JOBS only drives the parallel batch in verify/check/sweep , validate it ONLY for those (a stray
# CITE_JOBS in the env must not kill links/prove/lint/insert/flag/permalink, which never spawn xargs), but
# validate at DISPATCH (not inside cmd_verify) so check/sweep can't swallow the error into a silent PASS.
case "$cmd" in
  verify|check|sweep)
    case "${CITE_JOBS:-16}" in ''|*[!0-9]*) die "CITE_JOBS must be a positive integer (got '${CITE_JOBS}')";; esac
    [ "${CITE_JOBS:-16}" -ge 1 ] 2>/dev/null || die "CITE_JOBS must be >= 1 (got '${CITE_JOBS}')" ;;
esac
case "$cmd" in
  permalink) cmd_permalink "$@" ;;
  verify)    cmd_verify "$@" ;;
  preflight) cmd_preflight "$@" ;;
  links)     cmd_links "$@" ;;
  prove)     cmd_prove "$@" ;;
  lint)      cmd_lint "$@" ;;
  flag)      cmd_flag "$@" ;;
  insert)    cmd_insert "$@" ;;
  sweep)     cmd_sweep "$@" ;;
  check)     cmd_check "$@" ;;
  __vone)    _verify_emit "${1:-}" ;;
  version|--version|-V) [ "${CITE_JSON:-0}" = 1 ] && printf '{"version":"%s"}\n' "$VERSION" || printf 'cite %s\n' "$VERSION" ;;
  ""|-h|--help|help) usage 0 ;;
  *) die "unknown subcommand '$cmd' (try: cite help)" ;;
esac
