#!/usr/bin/env node
'use strict';
// cite , find the source behind a post's claims and emit VERIFIED citation links.
//
// the agent does the judgment (which claims warrant a cite, which source backs each, which lines);
// this script does the error-prone mechanics: a SHA-pinned + validated github permalink, a url that
// actually resolves, the prove/lint gates that mechanize "don't rewrite prose", and a safe insert.
// the agent decides WHAT to cite; the helper does the mechanics. See SKILL.md.
//
// node port of the original bash+perl tool (tag perl-final). zero npm deps: node built-ins only
// (global fetch, node:child_process for git, node:fs). portability + a substrate people trust.

const fs = require('node:fs');
const path = require('node:path');
const { execFileSync } = require('node:child_process');

const VERSION = '4.0.9';

// ---- global flags (set by the arg parser below) ----
let JSON_OUT = process.env.CITE_JSON === '1';
let XCHECK = process.env.CITE_XCHECK === '1';
let FIX = process.env.CITE_FIX === '1';
let REL = process.env.CITE_REL === '1';

function die(msg) {
  if (JSON_OUT) process.stdout.write(JSON.stringify({ error: msg, ok: false }) + '\n');
  process.stderr.write('cite: ' + msg + '\n');
  process.exit(1);
}

function usage(code) {
  process.stderr.write(`cite , verified citation links for an agent. The agent decides WHAT to cite; this builds + checks. Full doctrine: SKILL.md.

  cite verify <url> | cite verify -   resolves? HTTP code + dead-vs-gated hint + redirect (batch: parallel, JSONL)
  cite links <file>                   every link url (md / html href / refs / autolinks / bare), images excluded
  cite insert <file> <phrase> <url>   verify <url> + wrap the FIRST citable match (skips code + existing links)
  cite prove <file> [ref]             assert ONLY link markup changed vs ref (default HEAD); fails on any prose edit
  cite lint <file>                    catch the url-as-text half-fix (--fix syncs it)
  cite flag <post> <reason...>        record a dead link / dubious claim (with its url) to .cite-flags.md
  cite check <post> [base]            optional audit: verify all links + prove + lint -> PASS/ISSUES
  cite sweep <repo-dir> <base>        prove + lint over every changed .md (batch backstop)
  cite preflight <repo-dir>           (code mode) slug / HEAD / pushed / visibility
  cite permalink <repo-dir> <path> <start> [end] [--ref <ref>]   (code mode) sha-pinned, range-validated
  cite version

Flags: --json (links/verify/lint/check) , --crosscheck (verify) , --relative (links) , --fix (lint).
Use -- to end flags when a phrase/reason IS a flag token: cite insert post.md -- --fix <url>.
Note: prove/flag/check/sweep need the file in a git repo; links/verify/lint do not.
`);
  process.exit(code == null ? 2 : code);
}

// ---- git helpers (the one external dep; node is the runtime, fetch is built in) ----
function git(args, opts) {
  return execFileSync('git', args, Object.assign({ encoding: 'utf8', stdio: ['ignore', 'pipe', 'ignore'] }, opts || {}));
}
function gitOut(args) { try { return git(args); } catch { return null; } }
function gitOk(args) { try { git(args); return true; } catch { return false; } }

function ghSlug(url) {
  let u = url.replace(/\.git$/, '');
  if (u.startsWith('git@github.com:')) return u.slice('git@github.com:'.length);
  if (u.startsWith('https://github.com/')) return u.slice('https://github.com/'.length);
  return null;
}
function shaIsPushed(dir, sha) {
  const o = gitOut(['-C', dir, 'branch', '-r', '--contains', sha]);
  return !!(o && o.trim());
}

// ---- the ONE code-region pattern (html comment, fenced ```/~~~ block, double/single inline code).
// everything that must skip code consumes this one source so they can never diverge. ----
const CITE_CR = /<!--.*?-->|(?:`{3,}|~{3,})[^\n]*\n.*?\n[ \t]*(?:`{3,}|~{3,})[^\n]*|``.*?``|`[^`\n]+`/.source;
function maskCode(s) { return s.replace(new RegExp(CITE_CR, 'gs'), ''); }
function escapeRegex(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

function isFile(f) { try { return fs.statSync(f).isFile(); } catch { return false; } }
// ---- url helpers ----
// normalize for the redirect compare: drop the #fragment (node fetch strips it from res.url, so comparing
// with it always false-positives), then scheme + trailing slash. http->https / trailing-slash != a redirect.
function norm(u) { return u.replace(/#.*$/, '').replace(/^https?:\/\//, '').replace(/\/$/, ''); }
function hostRoot(u) { const m = u.match(/^(https?:\/\/[^/]+)/); return m ? m[1] + '/' : u; }
function codehint(code) {
  if (code === '403' || code === '429' || code === '503') return 'often bot/JS-gated , cross-check a non-gated source (registry index/api) before calling it dead';
  if (code === '404' || code === '410') return 'likely dead';
  if (code === '000') return 'no response / timeout';
  if (/^3/.test(code)) return 'redirect , prefer the final url';
  return 'not 200';
}

// ---- HTTP probe (fetch, follow redirects, 20s cap) -> {code, final} ----
async function probe(url) {
  const ac = new AbortController();
  const t = setTimeout(() => ac.abort(), 20000);
  try {
    const res = await fetch(url, { redirect: 'follow', signal: ac.signal });
    const out = { code: String(res.status), final: res.url || url };
    try { await res.body?.cancel(); } catch {}
    return out;
  } catch {
    return { code: '000', final: '' };
  } finally { clearTimeout(t); }
}

// resolve + classify one url -> {url, ok, code, redir, hint}
async function verifyOne(url) {
  const { code, final } = await probe(url);
  if (code === '200') {
    const redir = (final && norm(final) !== norm(url)) ? final : '';
    return { url, ok: true, code: '200', redir, hint: '' };
  }
  let hint = codehint(code);
  if (XCHECK) {
    const rcode = (await probe(hostRoot(url))).code;
    hint = rcode === '200'
      ? `host root is 200 but this path is ${code} , likely DEAD (page gone)`
      : `host root is also ${rcode} , likely a host-wide GATE not a dead page (confirm via a non-gated index)`;
  }
  return { url, ok: false, code, redir: '', hint };
}

function emitVerify(r) {
  if (r.ok) {
    if (JSON_OUT) return r.redir
      ? JSON.stringify({ url: r.url, ok: true, code: '200', final: r.redir })
      : JSON.stringify({ url: r.url, ok: true, code: '200' });
    return r.redir
      ? `ok    ${r.url}  -> ${r.redir}  (redirected , open the final page and confirm it still means the term before linking it)`
      : `ok    ${r.url}`;
  }
  if (JSON_OUT) return JSON.stringify({ url: r.url, ok: false, code: r.code, hint: r.hint });
  return `FAIL  ${r.url}  (HTTP ${r.code} , ${r.hint})`;
}

// run fn over items with bounded concurrency (replaces the xargs -P fan-out, in-process so there is
// no per-url process spawn at all).
async function pool(items, n, fn) {
  const out = new Array(items.length);
  let i = 0;
  const width = Math.max(1, Math.min(n, items.length));
  await Promise.all(Array.from({ length: width }, async () => {
    while (i < items.length) { const idx = i++; out[idx] = await fn(items[idx], idx); }
  }));
  return out;
}

function jobs() { return parseInt(process.env.CITE_JOBS || '16', 10); }

async function cmdVerify(args) {
  const url = args[0];
  if (!url) usage();
  if (url === '-') {
    const stdin = fs.readFileSync(0, 'utf8');
    const seen = new Set();
    const items = stdin.split('\n').map(s => s.trim()).filter(s => s && !seen.has(s) && seen.add(s));
    if (items.length === 0) return 0;
    const results = await pool(items, jobs(), verifyOne);
    if (results.some(r => r == null)) { // a worker threw -> fan-out broke; never read empty as all-clear
      process.stderr.write(`cite: verify produced no output for ${items.length} url(s) , the fan-out failed\n`);
      return 1;
    }
    for (const r of results) process.stdout.write(emitVerify(r) + '\n');
    return results.some(r => !r.ok) ? 1 : 0;
  }
  const r = await verifyOne(url);          // single-url path , one probe, used for both output and exit
  process.stdout.write(emitVerify(r) + '\n');
  return r.ok ? 0 : 1;
}

// ---- link extraction ----
function extractLinks(masked) {
  // collapse images ![alt](src) to alt BEFORE extraction (drop badge srcs; expose linked-badge targets)
  masked = masked.replace(/!\[([^\]]*)\]\((?:[^()\s]|\([^()\s]*\))*\)/g, '$1');
  const urls = [], rel = [];
  let m;
  const reInline = /\[[^\]]*\]\((https?:\/\/(?:[^()\s]|\([^()\s]*\))+)\)/g;
  while ((m = reInline.exec(masked))) urls.push(m[1]);
  const reHref = /href\s*=\s*(["']?)(https?:\/\/[^"'\s>]+)\1/gi;
  while ((m = reHref.exec(masked))) urls.push(m[2]);
  // ref-def targets feed urls (http) or rel (non-http) from the one ref-def pattern
  const reRef = /^[ ]{0,3}\[[^\]]+\]:\s+(\S+)/gm;
  while ((m = reRef.exec(masked))) { const u = m[1].replace(/^</, '').replace(/>$/, ''); (/^https?:\/\//.test(u) ? urls : rel).push(u); }
  const reAuto = /<(https?:\/\/[^>\s]+)>/g;
  while ((m = reAuto.exec(masked))) urls.push(m[1]);
  // bare urls: run ONLY over text with the structural links already removed, so the bare scanner can't
  // manufacture a truncated phantom of a link whose url contains a paren (e.g. .../Paxos_(computer_science)
  // -> a dead .../Paxos_). the structural extractors above already captured those correctly.
  const bareSrc = masked
    .replace(/\[[^\]]*\]\((?:[^()\s]|\([^()\s]*\))*\)/g, ' ')      // inline links/images
    .replace(/<a\b[^>]*?>.*?<\/a>/gis, ' ')                        // html anchors
    .replace(/href\s*=\s*(["'])[^"']*\1/gi, ' ')                   // stray href attrs
    .replace(/<https?:\/\/[^>\s]+>/g, ' ')                         // autolinks
    .replace(/^[ ]{0,3}\[[^\]]+\]:[ \t]+\S+/gm, ' ');             // ref-def targets
  const reBare = /(?:^|[\s(\[])(https?:\/\/[^\s<>()\[\]"']+)/gm;
  while ((m = reBare.exec(bareSrc))) urls.push(m[1].replace(/[.,;:!?]+$/, ''));
  // relative targets (inline + ref-def), non-http
  const reRelInline = /\[[^\]]*\]\(([^()\s][^()]*)\)/g;
  while ((m = reRelInline.exec(masked))) { if (!/^https?:\/\//.test(m[1])) rel.push(m[1]); }
  const dedup = a => { const s = new Set(); return a.filter(x => !s.has(x) && s.add(x)); };
  return { urls: dedup(urls), rel: dedup(rel) };
}

function cmdLinks(args) {
  const f = args[0];
  if (!f) usage();
  if (!isFile(f)) die(`links: no file '${f}'`);
  const masked = maskCode(fs.readFileSync(f, 'utf8'));
  const { urls, rel } = extractLinks(masked);
  if (JSON_OUT) { process.stdout.write(JSON.stringify({ urls, relative: rel }) + '\n'); return 0; }
  if (urls.length) process.stdout.write(urls.join('\n') + '\n');
  if (REL && rel.length) {
    process.stderr.write('relative links (not http , verify by hand; absolutize the load-bearing ones for portability):\n');
    process.stderr.write(rel.map(r => '  ' + r).join('\n') + '\n');
  }
  return 0;
}

// ---- prove: reduce a doc to reader-visible prose, compare to a ref ----
function strip(text) {
  const parts = text.split(new RegExp('(' + CITE_CR + ')', 's')); // odd indices = code regions, verbatim
  const tok = t => t.replace(/https?:\/\/[^\s<>"]+/g, '<URL>');
  for (let i = 0; i < parts.length; i++) {
    if (i % 2) continue;
    parts[i] = parts[i]
      .replace(/!?\[([^\]]*)\]\((?:[^()\s]|\([^()\s]*\))*\)/g, (m, t) => tok(t))   // inline link/image -> visible text
      .replace(/<a\b[^>]*?>(.*?)<\/a>/gis, (m, t) => tok(t))                       // html anchor -> visible text
      .replace(/^([ ]{0,3}\[[^\]]+\]:[ \t]+)\S+/gm, '$1<URL>');                    // ref-def target: markup
  }
  return parts.join('').replace(/\n+$/, '');   // drop trailing newline(s) so a pure EOF-newline delta (editors add one on save) isn't a false PROSE-CHANGED (perl's $() did this)
}

function resolveRel(f) {
  const dir = fs.realpathSync(path.dirname(f));
  const base = path.basename(f);
  const root = gitOut(['-C', dir, 'rev-parse', '--show-toplevel']);
  if (!root) return null;
  const r = root.trim();
  return { dir, base, root: r, rel: dir === r ? base : path.relative(r, path.join(dir, base)) };
}

function cmdProve(args) {
  const f = args[0], ref = args[1] || 'HEAD';
  if (!f) usage();
  if (!isFile(f)) die(`prove: no file '${f}'`);
  const R = resolveRel(f);
  if (!R) die(`prove: not in a git repo: ${f}`);
  const old = gitOut(['-C', R.root, 'show', `${ref}:${R.rel}`]);
  if (old == null) die(`prove: '${R.rel}' not found at ${ref} (new file? nothing to prove against)`);
  const olds = strip(old);
  const news = strip(fs.readFileSync(f, 'utf8'));
  if (olds === news) {
    process.stdout.write(`prove: ${R.rel} , only link markup changed; prose intact.\n`);
    if (!args[1] && gitOk(['-C', R.root, 'diff', '--quiet', 'HEAD', '--', R.rel])) {
      process.stderr.write(`prove: note , ${R.rel} is identical to HEAD (nothing to prove). if you already committed the cites, pass the base ref: cite prove ${R.base} <base>.\n`);
    }
    return 0;
  }
  process.stderr.write(`prove: PROSE CHANGED in ${R.rel} , cite must not rewrite prose. visible-text diff (- was, + now):\n`);
  try {
    const a = path.join(require('node:os').tmpdir(), 'cite-o-' + process.pid);
    const b = path.join(require('node:os').tmpdir(), 'cite-n-' + process.pid);
    fs.writeFileSync(a, olds + '\n'); fs.writeFileSync(b, news + '\n');
    try { execFileSync('diff', [a, b], { stdio: ['ignore', 2, 2] }); } catch {}   // diff body -> stderr (stdout stays clean)
    fs.rmSync(a, { force: true }); fs.rmSync(b, { force: true });
  } catch {}
  process.exit(1);
}

// ---- lint: the url-as-text half-fix ----
function lintScan(f) {
  const masked = maskCode(fs.readFileSync(f, 'utf8'));
  const out = [];
  let m;
  const reMd = /(?<!\!)\[([^\]]*)\]\(((?:[^()\s]|\([^()\s]*\))+)\)/g;
  while ((m = reMd.exec(masked))) { const t = m[1].trim(), h = m[2]; if (/^https?:\/\//.test(t) && t !== h) out.push({ text: t, href: h }); }   // trim: md renders link text trimmed, so " https://x" IS a url-as-text half-fix
  const reHtml = /<a\b[^>]*?href\s*=\s*(["']?)([^"'\s>]+)\1[^>]*>(.*?)<\/a>/gis;
  while ((m = reHtml.exec(masked))) { const h = m[2]; const t = m[3].replace(/<[^>]*>/gs, '').trim(); if (/^https?:\/\//.test(t) && t !== h) out.push({ text: t, href: h }); }
  return out;
}

function cmdLint(args) {
  const f = args[0];
  if (!f) usage();
  if (!isFile(f)) die(`lint: no file '${f}'`);
  let fixed = 0;
  if (FIX) {
    const before = lintScan(f).length;
    let s = fs.readFileSync(f, 'utf8');
    const cr = new RegExp('(' + CITE_CR + ')|(?<!\\!)\\[([^\\]]*)\\]\\(((?:[^()\\s]|\\([^()\\s]*\\))+)\\)', 'gs');
    s = s.replace(cr, (m, c, t, h) => c !== undefined ? c : ((/^https?:\/\//.test(t) && t !== h) ? `[${h}](${h})` : `[${t}](${h})`));
    const ch = new RegExp('(' + CITE_CR + ')|(<a\\b[^>]*?href\\s*=\\s*["\']?)([^"\'\\s>]+)(["\']?[^>]*>)(.*?)(</a>)', 'gis');
    s = s.replace(ch, (m, c, p, h, mid, t, q) => {
      if (c !== undefined) return c;
      const tt = t.replace(/<[^>]*>/gs, '');
      return (/^https?:\/\//.test(tt) && tt !== h) ? `${p}${h}${mid}${h}${q}` : `${p}${h}${mid}${t}${q}`;
    });
    fs.writeFileSync(f, s);
    fixed = before - lintScan(f).length;
  }
  const out = lintScan(f);
  if (JSON_OUT) {
    if (out.length === 0) { process.stdout.write(JSON.stringify({ clean: true, fixed, offenders: [] }) + '\n'); return 0; }
    process.stdout.write(JSON.stringify({ clean: false, fixed, offenders: out }) + '\n'); return 1;
  }
  if (FIX) process.stdout.write(`lint --fix: ${f} , synced ${fixed} url-as-text half-fix(es) to their href.\n`);
  if (out.length === 0) { if (!FIX) process.stdout.write(`lint: ${f} , clean (no url-as-visible-text half-fixes).\n`); return 0; }
  process.stderr.write(`lint: ${f} , a link shows a url as its visible text that differs from its href (run --fix, or sync manually):\n`);
  process.stderr.write(out.map(o => `  half-fix: ${o.text}  ->  ${o.href}`).join('\n') + '\n');
  return 1;
}

// ---- flag ----
function cmdFlag(args) {
  const f = args[0];
  const reason = args.slice(1).join(' ');
  if (!f || !reason) die('flag: usage , cite flag <post> <reason...>');
  if (!isFile(f)) die(`flag: no file '${f}'`);
  const R = resolveRel(f);
  if (!R) die(`flag: not in a git repo: ${f}`);
  const ts = new Date().toISOString().slice(0, 10);
  fs.appendFileSync(path.join(R.root, '.cite-flags.md'), `- [${ts}] ${R.rel} , ${reason}\n`);
  process.stdout.write(`flag: recorded to ${R.root}/.cite-flags.md\n`);
  return 0;
}

function isFlagged(flagsFile, url) {
  let txt;
  try { txt = fs.readFileSync(flagsFile, 'utf8'); } catch { return false; }
  const urls = (txt.match(/https?:\/\/[^\s]+/g) || []).map(u => u.replace(/[.,;:!?]*$/, ''));
  return urls.includes(url.replace(/[.,;:!?]*$/, ''));   // strip the query url too, so an inline href ending in punctuation matches a flagged bare url consistently
}

// ---- insert ----
function protSplit(text) {
  // protect every NON-PROSE construct so insert only ever wraps a phrase in real prose: code | a linked
  // image [![alt](img)](href) | an inline link or image !?[..](..) | a whole html anchor | ANY other html
  // tag (<img>, <br>, autolinks <http..>, etc., caught broadly so the html side can't whack-a-mole). order
  // matters: the linked-image + whole-anchor patterns come before the narrower ones.
  const prot = new RegExp('(' + CITE_CR
    + '|\\[!\\[[^\\]]*\\]\\([^)]*\\)\\]\\((?:[^()\\s]|\\([^()\\s]*\\))*\\)'   // linked image [![alt](img)](href)
    + '|!?\\[[^\\]]*\\]\\((?:[^()\\s]|\\([^()\\s]*\\))*\\)'                  // inline link OR image
    + '|<a\\b[^>]*?>.*?<\\/a>'                                              // whole html anchor (protect its text too)
    + '|<\\/?[a-zA-Z][^>]*>'                                               // any html tag (<img>, </p>, ...) + autolinks <http..>; the letter/slash start avoids matching math prose like "0 < n ... 2 > x"
    + ')', 's');
  return text.split(prot); // odd indices = protected (code or existing link)
}

async function cmdInsert(args) {
  const f = args[0], phrase = args[1], url = args[2];
  if (!f || !phrase || !url) die('insert: usage , cite insert <file> <phrase> <url>');
  if (!isFile(f)) die(`insert: no file '${f}'`);
  const src = fs.readFileSync(f, 'utf8');
  const q = new RegExp(escapeRegex(phrase), 'g');
  const parts = protSplit(src);
  let n = 0;
  for (let i = 0; i < parts.length; i++) { if (i % 2) continue; const mm = parts[i].match(q); if (mm) n += mm.length; }
  if (n < 1) die(`insert: '${phrase}' not found in citable prose in ${f} (it may appear only inside code or an existing link, which cite won't touch)`);
  const { code } = await probe(url);
  if (code !== '200') die(`insert: ${url} -> HTTP ${code} (${codehint(code)}) , not inserting an unverified link`);
  const html = /\.html?$/.test(f);
  const repl = html ? `<a href="${url}">${phrase}</a>` : `[${phrase}](${url})`;
  let done = false;
  for (let i = 0; i < parts.length && !done; i++) {
    if (i % 2) continue;
    const q1 = new RegExp(escapeRegex(phrase));
    if (q1.test(parts[i])) { parts[i] = parts[i].replace(q1, () => repl); done = true; }
  }
  fs.writeFileSync(f, parts.join(''));
  process.stdout.write(`insert: wrapped "${phrase}" -> ${url} in ${f}\n`);
  if (n > 1) process.stderr.write(`insert: note , "${phrase}" has ${n} citable occurrences; linked the FIRST. pass a longer unique phrase to target another.\n`);
  return 0;
}

// ---- sweep ----
async function cmdSweep(args) {
  const dir = args[0], base = args[1];
  if (!dir || !base) die('sweep: usage , cite sweep <repo-dir> <base-ref>');
  if (!fs.existsSync(dir) || !fs.statSync(dir).isDirectory()) die(`sweep: no dir '${dir}'`);
  const root = gitOut(['-C', dir, 'rev-parse', '--show-toplevel']);
  if (!root) die(`sweep: not a git repo: ${dir}`);
  const r = root.trim();
  if (!gitOk(['-C', r, 'rev-parse', '--verify', `${base}^{commit}`])) die(`sweep: cannot resolve base ref '${base}'`);
  const files = (gitOut(['-C', r, 'diff', '--name-only', base, '--', '*.md']) || '').split('\n').filter(Boolean);
  if (files.length === 0) { process.stdout.write(`sweep: no changed .md files vs ${base}.\n`); return 0; }
  let n = 0, pf = 0, lf = 0;
  for (const rel of files) {
    n++;
    const abs = path.join(r, rel);
    if (!fs.existsSync(abs)) { process.stdout.write(`DELETED        ${rel}  (skipped , not a prose/half-fix offender)\n`); continue; }   // visible, but not counted as an offender (perl-final mislabeled deletions as both)
    if (gitOk(['-C', r, 'cat-file', '-e', `${base}:${rel}`])) {
      try { if (!quietProve(abs, base)) { process.stdout.write(`PROSE-CHANGED  ${rel}\n`); pf++; } } catch {}
    }
    try { if (lintScan(abs).length > 0) { process.stdout.write(`HALF-FIX       ${rel}\n`); lf++; } } catch {}
  }
  process.stdout.write(`sweep: ${n} changed .md vs ${base} , ${pf} prose-changed, ${lf} half-fix.\n`);
  return (pf === 0 && lf === 0) ? 0 : 1;
}

// prove without output/exit , returns true if prose intact, false if changed (for sweep/check).
function quietProve(f, ref) {
  const R = resolveRel(f);
  if (!R) return true;
  const old = gitOut(['-C', R.root, 'show', `${ref}:${R.rel}`]);
  if (old == null) return true;
  return strip(old) === strip(fs.readFileSync(f, 'utf8'));
}

// ---- check ----
async function cmdCheck(args) {
  const f = args[0], base = args[1] || 'HEAD';
  if (!f) usage();
  if (!isFile(f)) die(`check: no file '${f}'`);
  const dir = fs.realpathSync(path.dirname(f));
  const rootRaw = gitOut(['-C', dir, 'rev-parse', '--show-toplevel']);
  const root = rootRaw ? rootRaw.trim() : '';
  const flagsFile = root ? path.join(root, '.cite-flags.md') : '';
  const masked = maskCode(fs.readFileSync(f, 'utf8'));
  const { urls } = extractLinks(masked);
  const nlink = urls.length;
  const results = nlink ? await pool(urls, jobs(), verifyOne) : [];
  let nfail = 0, flagged = 0; const failedUrls = [];
  for (const r of results) {
    if (r.ok) continue;
    if (flagsFile && fs.existsSync(flagsFile) && isFlagged(flagsFile, r.url)) flagged++;
    else { nfail++; failedUrls.push(r.url); }
  }
  // prove with a reason (distinguish a real prose change from prove being inapplicable)
  let pstatus = 'ok', pfail = 0, rel = '';
  if (!root) pstatus = 'skipped (not a git repo)';
  else {
    rel = dir === root ? path.basename(f) : path.relative(root, path.join(dir, path.basename(f)));
    if (!gitOk(['-C', root, 'cat-file', '-e', `${base}:${rel}`])) pstatus = `skipped (file absent at ${base})`;
    else if (quietProve(f, base)) pstatus = 'prose intact';
    else { pstatus = `PROSE CHANGED vs ${base}`; pfail = 1; }
  }
  const off = lintScan(f);
  const nlint = off.length;
  let flagrec = 0;
  if (flagsFile && fs.existsSync(flagsFile)) flagrec = (fs.readFileSync(flagsFile, 'utf8').match(/^- /gm) || []).length;
  const ok = (nfail === 0 && pfail === 0 && nlint === 0);
  if (JSON_OUT) {
    process.stdout.write(JSON.stringify({
      file: f, links: nlink, link_failures: nfail, flagged_known: flagged, failed_urls: failedUrls,
      prove: pstatus, half_fixes: nlint, offenders: off, flags_recorded: flagrec, ok,
    }) + '\n');
    return ok ? 0 : 1;
  }
  process.stdout.write(`check ${f} (vs ${base}):\n`);
  process.stdout.write(flagged > 0
    ? `  links: ${nlink} checked, ${nfail} failed (${flagged} flagged, known)\n`
    : `  links: ${nlink} checked, ${nfail} failed\n`);
  if (nfail > 0) for (const u of failedUrls) process.stdout.write(`         dead: ${u}\n`);
  process.stdout.write(`  prove: ${pstatus}\n`);
  process.stdout.write(`  lint:  ${nlint === 0 ? 'clean' : nlint + ' half-fix(es) , run cite lint --fix'}\n`);
  if (flagrec > 0) process.stdout.write(`  flags: ${flagrec} recorded in .cite-flags.md (read it , url-less claim flags do not show above)\n`);
  process.stdout.write(ok ? '  => PASS\n' : '  => ISSUES\n');
  return ok ? 0 : 1;
}

// ---- permalink (code mode) ----
function cmdPermalink(args) {
  let ref = '', pos = [], i = 0;
  while (i < args.length) {
    if (args[i] === '--ref') { ref = args[i + 1] || ''; if (!ref) die('permalink: --ref needs a value'); i += 2; continue; }
    if (args[i].startsWith('--ref=')) { ref = args[i].slice(6); i++; continue; }
    pos.push(args[i]); i++;
  }
  if (pos.length > 4) die('permalink: too many arguments');
  const [dir, p, start, end] = pos;
  if (!dir || !p || !start) usage();
  if (!/^[0-9]+$/.test(start)) die('permalink: start line must be a number');
  if (end != null && !/^[0-9]+$/.test(end)) die('permalink: end line must be a number');
  if (!(parseInt(start, 10) >= 1)) die(`permalink: start line must be >= 1 (got ${start})`);
  if (end != null && !(parseInt(end, 10) >= parseInt(start, 10))) die(`permalink: end (${end}) is before start (${start})`);
  if (!gitOk(['-C', dir, 'rev-parse', '--is-inside-work-tree'])) die(`not a git repo: ${dir}`);
  const remote = gitOut(['-C', dir, 'remote', 'get-url', 'origin']);
  if (!remote) die(`no 'origin' remote in ${dir}`);
  const slug = ghSlug(remote.trim());
  if (!slug) die(`origin is not a github remote: ${remote.trim()}`);
  let sha;
  if (ref) {
    sha = gitOut(['-C', dir, 'rev-parse', '--verify', `${ref}^{commit}`]);
    if (!sha) die(`cannot resolve ref '${ref}' in ${dir}`);
    sha = sha.trim();
  } else {
    sha = gitOut(['-C', dir, 'rev-parse', 'HEAD']);
    if (!sha) die(`cannot resolve HEAD in ${dir}`);
    sha = sha.trim();
    if (!shaIsPushed(dir, sha)) die(`HEAD (${sha}) isn't pushed to any remote , the permalink would 404. push it, or pass --ref origin/<branch> to pin to a public commit.`);
  }
  if (!gitOk(['-C', dir, 'cat-file', '-e', `${sha}:${p}`])) die(`no '${p}' at ${sha}`);
  const content = gitOut(['-C', dir, 'show', `${sha}:${p}`]);
  const n = (content == null || content === '') ? 0 : content.split('\n').length - (content.endsWith('\n') ? 1 : 0);
  const last = parseInt(end || start, 10);
  if (n === 0 || !(last <= n)) die(`line ${last} out of range (${p} has ${n} lines at ${sha})`);
  if (end && end !== start) process.stdout.write(`https://github.com/${slug}/blob/${sha}/${p}#L${start}-L${end}\n`);
  else process.stdout.write(`https://github.com/${slug}/blob/${sha}/${p}#L${start}\n`);
  return 0;
}

function cmdPreflight(args) {
  const dir = args[0];
  if (!dir) usage();
  if (!gitOk(['-C', dir, 'rev-parse', '--is-inside-work-tree'])) die(`not a git repo: ${dir}`);
  let remote = gitOut(['-C', dir, 'remote', 'get-url', 'origin']); remote = remote ? remote.trim() : '(none)';
  const slug = ghSlug(remote) || `(not a github remote: ${remote})`;
  let sha = gitOut(['-C', dir, 'rev-parse', 'HEAD']); sha = sha ? sha.trim() : '(no HEAD)';
  const pushed = shaIsPushed(dir, sha) ? 'yes' : 'no';
  const dirty = (gitOut(['-C', dir, 'status', '--porcelain']) || '').trim() ? 'yes' : 'no';
  let vis = '';
  try { vis = execFileSync('gh', ['repo', 'view', slug, '--json', 'visibility', '-q', '.visibility'], { encoding: 'utf8', stdio: ['ignore', 'pipe', 'ignore'] }).trim().toLowerCase(); } catch {}
  if (!vis) vis = 'unknown';
  process.stdout.write(`repo:       ${dir}\nslug:       ${slug}\nvisibility: ${vis}\nHEAD:       ${sha}\npushed:     ${pushed}\ndirty:      ${dirty}\n`);
  if (pushed !== 'yes') process.stdout.write('note:       HEAD is not pushed , pin with `cite permalink ... --ref origin/<branch>` (or push first), else the links 404.\n');
  if (vis === 'private') process.stdout.write('note:       repo is PRIVATE , do NOT cite it; its links 404 for anyone but you. find a public source or skip the cite.\n');
  return 0;
}

// ---- arg parsing + dispatch ----
async function main() {
  const argv = process.argv.slice(2);
  const rest = [];
  let endopts = false;
  for (const x of argv) {
    if (endopts) { rest.push(x); continue; }
    switch (x) {
      case '--': endopts = true; break;
      case '--json': JSON_OUT = true; break;
      case '--crosscheck': XCHECK = true; break;
      case '--fix': FIX = true; break;
      case '--relative': REL = true; break;
      default: rest.push(x);
    }
  }
  const cmd = rest[0] || '';
  const args = rest.slice(1);

  // CITE_JOBS drives the parallel batch in verify/check/sweep only , validate it just for those, loudly,
  // so a typo can't silently disable verification (and the others aren't falsely killed by a stray value).
  if (cmd === 'verify' || cmd === 'check' || cmd === 'sweep') {
    const j = process.env.CITE_JOBS;
    if (j !== undefined && (!/^[0-9]+$/.test(j) || parseInt(j, 10) < 1)) die(`CITE_JOBS must be a positive integer (got '${j}')`);
  }

  let rc = 0;
  switch (cmd) {
    case 'permalink': rc = cmdPermalink(args); break;
    case 'verify': rc = await cmdVerify(args); break;
    case 'preflight': rc = cmdPreflight(args); break;
    case 'links': rc = cmdLinks(args); break;
    case 'prove': rc = cmdProve(args); break;
    case 'lint': rc = cmdLint(args); break;
    case 'flag': rc = cmdFlag(args); break;
    case 'insert': rc = await cmdInsert(args); break;
    case 'sweep': rc = await cmdSweep(args); break;
    case 'check': rc = await cmdCheck(args); break;
    case 'version': case '--version': case '-V':
      process.stdout.write(JSON_OUT ? JSON.stringify({ version: VERSION }) + '\n' : `cite ${VERSION}\n`); break;
    case '': case '-h': case '--help': case 'help': usage(0); break;
    default: die(`unknown subcommand '${cmd}' (try: cite help)`);
  }
  process.exitCode = rc || 0;   // NOT process.exit(): let the event loop drain stdout (a hard exit truncates a piped batch)
}

main().catch(e => die(String(e && e.message || e)));
